# --- Agent runtime configuration ---
PROJECT_ID=eastern-map-498917-i6

# MCP Toolbox endpoint. For local runs against a private Cloud Run Toolbox,
# start an authenticated proxy and point at it:
#   gcloud run services proxy toolbox --region=us-east1 --port=5000
MCP_TOOLBOX_SERVER_URL=http://127.0.0.1:5000

# --- Model: Vertex AI (uses Application Default Credentials, no API key) ---
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=eastern-map-498917-i6
GOOGLE_CLOUD_LOCATION=us-central1
MODEL=gemini-2.5-flash

# --- Alternative: Google AI Studio API key instead of Vertex ---
# Comment out the four Vertex lines above and use:
# GOOGLE_API_KEY=replace-with-your-google-ai-studio-key
